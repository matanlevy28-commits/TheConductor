{
  "_comment": "Example hooks block for agent-monitor. Copy the 'hooks' section into your project's .claude/settings.json (or settings.local.json for personal/gitignored). Adjust the absolute paths to match where you copied agent-monitor/ — typically <your-project>/.claude/agent-monitor/.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"<absolute-path-to>/agent-monitor/logger.py\"",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"<absolute-path-to>/agent-monitor/logger.py\"",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"<absolute-path-to>/agent-monitor/logger.py\"",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"<absolute-path-to>/agent-monitor/reporter.py\"",
            "timeout": 30,
            "statusMessage": "Generating agent monitoring report..."
          }
        ]
      }
    ]
  }
}
